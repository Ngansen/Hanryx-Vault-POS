{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["hanryx", "pi", "operator"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HanryxVault Pi Operator",
  "uid": "hanryx-pi-ops",
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "ugreen_device",
        "label": "UGreen device",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(node_disk_io_time_seconds_total{device=~\"sd[a-z]+|nvme[0-9]+n[0-9]+\"}, device)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": true, "text": "sda", "value": "sda" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 2,
      "title": "RAM usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 3,
      "title": "SoC temperature",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(avg(node_hwmon_temp_celsius) * 9 / 5) + 32", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "fahrenheit",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 149 },
            { "color": "red", "value": 176 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 5, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "node_time_seconds - node_boot_time_seconds", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "title": "Load (1m)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 5, "x": 19, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "node_load1", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 4 },
            { "color": "red", "value": 8 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 6,
      "title": "UGreen 1 TB (/mnt/cards) — used",
      "type": "gauge",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/mnt/cards\"} / node_filesystem_size_bytes{mountpoint=\"/mnt/cards\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "options": { "showThresholdLabels": true, "showThresholdMarkers": true }
    },
    {
      "id": 7,
      "title": "UGreen 1 TB — free space over time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "node_filesystem_avail_bytes{mountpoint=\"/mnt/cards\"}", "refId": "A", "legendFormat": "free" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20, "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "SD card (/) — used",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "options": { "showThresholdMarkers": true }
    },
    {
      "id": 9,
      "title": "Network in / out",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*|tailscale.*\"}[1m]) * 8", "refId": "A", "legendFormat": "in {{device}}" },
        { "expr": "-rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*|tailscale.*\"}[1m]) * 8", "refId": "B", "legendFormat": "out {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 15, "lineWidth": 1, "drawStyle": "line" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "title": "UGreen disk IOPS — $ugreen_device",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_disk_reads_completed_total{device=~\"$ugreen_device\"}[1m])", "refId": "A", "legendFormat": "read {{device}}" },
        { "expr": "-rate(node_disk_writes_completed_total{device=~\"$ugreen_device\"}[1m])", "refId": "B", "legendFormat": "write {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "iops", "custom": { "fillOpacity": 15, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "title": "UGreen disk throughput — $ugreen_device",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{device=~\"$ugreen_device\"}[1m])", "refId": "A", "legendFormat": "read {{device}}" },
        { "expr": "-rate(node_disk_written_bytes_total{device=~\"$ugreen_device\"}[1m])", "refId": "B", "legendFormat": "write {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
