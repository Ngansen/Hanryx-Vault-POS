# Copy this file to .env and fill in your values before running docker compose up
# docker compose automatically reads .env from the same directory

# ── Database ──────────────────────────────────────────────────────────────────
# Shared PostgreSQL instance. Two databases are created automatically:
#   vaultpos   → Flask POS server
#   storefront → HanRyx-Vault public storefront
DB_PASSWORD=replace-with-a-strong-db-password

# ── Security (CHANGE THESE before going live) ─────────────────────────────────
# SESSION_SECRET is shared between the POS and the storefront.
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD=replace-with-a-strong-password

# ── Zettle payments (POS) ─────────────────────────────────────────────────────
ZETTLE_CLIENT_ID=
ZETTLE_CLIENT_SECRET=
ZETTLE_REDIRECT_URI=https://hanryxvault.tailcfc0a3.ts.net/zettle/callback

# ── PayPal checkout (storefront) ──────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── Pokémon TCG API (optional, free tier = 1 000 req/day; with key = 20 000) ──
# Shared between the POS (card enrichment) and the storefront (product lookup).
PTCG_API_KEY=

# ── Two-way stock sync ────────────────────────────────────────────────────────
# URL of the HanRyx-Vault storefront. When a sale is recorded on the POS, it
# automatically pushes stock decrements here so the website stays accurate.
# Defaults to the Docker-internal address — usually no change needed on the Pi.
# STOREFRONT_URL=http://storefront:3000

# ── Email notifications (optional) ────────────────────────────────────────────
# Use a Gmail App Password — NOT your main Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_APP_PASSWORD=
# Optional: send alerts to a different address than SMTP_USER
# NOTIFY_EMAIL=you@example.com

# ── OpenAI (card photo identification via GPT-4o Vision) ──────────────────────
# Get your key at https://platform.openai.com/api-keys
# Leave blank to disable the photo-ID feature.
OPENAI_API_KEY=

# ── Inventory Scanner (GitHub private repo sync) ──────────────────────────────
# Your GitHub Personal Access Token (classic, repo:read scope).
# Create at: GitHub → Settings → Developer settings → Personal access tokens (classic)
GITHUB_TOKEN=

# Optionally, set the deployed URL of your Inventory-Scanner app for fastest sync.
# If blank, the Pi falls back to the GitHub API (requires GITHUB_TOKEN above).
# Example: https://inventory-scanner.yourusername.repl.co/api/inventory
# INVENTORY_SCANNER_URL=

# ── Satellite Pi auth (set the same value on the satellite Pi) ────────────────
# SATELLITE_TOKEN=replace-with-a-long-random-token
