# Copy this file to .env and fill in your values before running docker compose up
# docker compose automatically reads .env from the same directory

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultpos:vaultpos@db:5432/vaultpos

# ── Security (CHANGE THESE before going live) ───────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD=replace-with-a-strong-password

# ── Zettle payments ──────────────────────────────────────────────────────────
ZETTLE_CLIENT_ID=
ZETTLE_CLIENT_SECRET=
ZETTLE_REDIRECT_URI=https://hanryxvault.tailcfc0a3.ts.net/zettle/callback

# ── Pokémon TCG API (optional, free tier = 1 000 req/day; with key = 20 000) ─
PTCG_API_KEY=

# ── Cloud inventory sync (optional, comma-separated URLs) ───────────────────
# CLOUD_INVENTORY_SOURCES=https://example.com/api/inventory,https://other.com/api/products
