# ──────────────────────────────────────────────────────────────────────────────
# HanRyx-Vault Card Recognizer — hybrid OCR + perceptual-hash service.
#
# Replaces the previous pokemon-card-recognizer (CNN) build:
#   • ~10× faster cold-start (no torch / torchvision)
#   • ~7× smaller image (~400 MB vs ~3 GB)
#   • Higher accuracy in practice — Tesseract reads the printed card number
#     verbatim, and a 64-bit perceptual hash on the artwork crop is the
#     same technique TCGplayer / PriceCharting use in production.
#
# Endpoints (unchanged, drop-in compatible with server.py's proxy):
#   POST /recognize/image  — multipart `image`            → top candidates
#   POST /recognize/video  — multipart `video`            → per-frame results
#   POST /recognize/scan   — multipart `image`, JSON resp with method & conf
#   GET  /healthz                                          → liveness + db stats
# ──────────────────────────────────────────────────────────────────────────────
# Pinned point release so `docker compose build` on the Pi is reproducible.
# Bump deliberately — torch/easyocr/opencv behavior is sensitive to the
# underlying CPython and bookworm-slim point release.
#
# The trailing @sha256:… is the content-addressable digest of the multi-arch
# manifest list. Tags on Docker Hub are mutable in principle (a compromised
# upstream could re-push the same tag with different bits); pinning by digest
# makes the pull tamper-evident — substituted bits change the digest and
# `docker pull` refuses them. The tag is kept for human readability only.
# Keep this digest in lock-step with the one in `../Dockerfile` (same base
# image) — see `../docs/REPRODUCIBILITY.md` for the bump procedure.
FROM python:3.11.10-slim-bookworm@sha256:840e180ebcc6e5c8efab209c43f5e40fd2af98cb49db5c7103c90539c56bb30e

# ── apt snapshot pin (DISABLED) ──────────────────────────────────────────────
# snapshot.debian.org is unreachable from Docker BuildKit on the Pi after the
# data-root migration. Using default Debian repos from the base image instead.
# Base image is pinned by @sha256 digest so the Debian release is still locked.
# Re-enable when Docker networking to snapshot.debian.org is fixed — see
# `../docs/REPRODUCIBILITY.md` for the procedure.
# ARG APT_SNAPSHOT_DATE=20260415T022652Z

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

# Tesseract + per-language traineddata so OCR works across EN / KR / JP / CHS.
# libpq5 = psycopg2 runtime; ffmpeg + libGL = opencv video & image decode.
RUN apt-get update && apt-get install -y --no-install-recommends \
        tesseract-ocr \
        tesseract-ocr-eng \
        tesseract-ocr-kor \
        tesseract-ocr-jpn \
        tesseract-ocr-chi-sim \
        tesseract-ocr-chi-tra \
        ffmpeg \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libpq5 \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
# `requirements.txt` is generated by `../scripts/lock-python-deps.sh recognizer`
# from `requirements.in` — every transitive dep is pinned to a specific version
# plus a sha256 hash. `--require-hashes` makes pip fail loudly if anything drifts.
COPY requirements.txt /app/requirements.txt
RUN pip install --require-hashes -r /app/requirements.txt

COPY server.py /app/server.py

EXPOSE 8081
CMD ["python", "-u", "server.py"]
