# ──────────────────────────────────────────────────────────────────────────────
# HanRyx-Vault Card Recognizer — hybrid OCR + perceptual-hash service.
#
# Replaces the previous pokemon-card-recognizer (CNN) build:
#   • ~10× faster cold-start (no torch / torchvision)
#   • ~7× smaller image (~400 MB vs ~3 GB)
#   • Higher accuracy in practice — Tesseract reads the printed card number
#     verbatim, and a 64-bit perceptual hash on the artwork crop is the
#     same technique TCGplayer / PriceCharting use in production.
#
# Endpoints (unchanged, drop-in compatible with server.py's proxy):
#   POST /recognize/image  — multipart `image`            → top candidates
#   POST /recognize/video  — multipart `video`            → per-frame results
#   POST /recognize/scan   — multipart `image`, JSON resp with method & conf
#   GET  /healthz                                          → liveness + db stats
# ──────────────────────────────────────────────────────────────────────────────
# Pinned point release so `docker compose build` on the Pi is reproducible.
# Bump deliberately — torch/easyocr/opencv behavior is sensitive to the
# underlying CPython and bookworm-slim point release.
FROM python:3.11.10-slim-bookworm

# ── apt snapshot pin ─────────────────────────────────────────────────────────
# Lock apt to a specific point in time on snapshot.debian.org so two
# `docker compose build` runs install byte-identical .deb files. Without this,
# Debian security updates between rebuilds silently change the bits in the
# image (e.g. ffmpeg, libpq5). Bump APT_SNAPSHOT_DATE deliberately — see
# `../docs/REPRODUCIBILITY.md` for the full bump procedure.
ARG APT_SNAPSHOT_DATE=20260415T000000Z

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

RUN set -eux; \
    rm -f /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources; \
    { \
        echo "Types: deb"; \
        echo "URIs: https://snapshot.debian.org/archive/debian/${APT_SNAPSHOT_DATE}/"; \
        echo "Suites: bookworm bookworm-updates"; \
        echo "Components: main"; \
        echo "Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg"; \
        echo "Check-Valid-Until: no"; \
        echo ""; \
        echo "Types: deb"; \
        echo "URIs: https://snapshot.debian.org/archive/debian-security/${APT_SNAPSHOT_DATE}/"; \
        echo "Suites: bookworm-security"; \
        echo "Components: main"; \
        echo "Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg"; \
        echo "Check-Valid-Until: no"; \
    } > /etc/apt/sources.list.d/snapshot.sources

# Tesseract + per-language traineddata so OCR works across EN / KR / JP / CHS.
# libpq5 = psycopg2 runtime; ffmpeg + libGL = opencv video & image decode.
RUN apt-get -o Acquire::Check-Valid-Until=false update && apt-get install -y --no-install-recommends \
        tesseract-ocr \
        tesseract-ocr-eng \
        tesseract-ocr-kor \
        tesseract-ocr-jpn \
        tesseract-ocr-chi-sim \
        tesseract-ocr-chi-tra \
        ffmpeg \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libpq5 \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
# `requirements.txt` is generated by `../scripts/lock-python-deps.sh recognizer`
# from `requirements.in` — every transitive dep is pinned to a specific version
# plus a sha256 hash. `--require-hashes` makes pip fail loudly if anything drifts.
COPY requirements.txt /app/requirements.txt
RUN pip install --require-hashes -r /app/requirements.txt

COPY server.py /app/server.py

EXPOSE 8081
CMD ["python", "-u", "server.py"]
