[Unit]
Description=HanryxVault Satellite Sync (push sales to home, pull inventory)
After=network-online.target hanryxvault.service
Wants=network-online.target
Requires=hanryxvault.service

[Service]
Type=oneshot
User=hanryxvault
WorkingDirectory=/opt/hanryxvault
ExecStart=/opt/hanryxvault/venv/bin/python3 /opt/hanryxvault/satellite_sync.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hanryxvault-sync
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
