# Pinned point release so `docker compose build` on the Pi is reproducible.
# Keep in lock-step with the runtime stage's FROM below — the venv built here
# is copied into the runtime image, so the two Pythons MUST match.
FROM python:3.11.10-slim-bookworm AS builder

# ── apt snapshot pin ─────────────────────────────────────────────────────────
# Lock apt to a specific point in time on snapshot.debian.org so two
# `docker compose build` runs install byte-identical .deb files. Without this,
# Debian security updates between rebuilds silently change the bits in the
# image (e.g. tesseract-ocr, libpq5).
#
# Bump APT_SNAPSHOT_DATE deliberately when picking up security updates — see
# `docs/REPRODUCIBILITY.md` for the full bump procedure.
ARG APT_SNAPSHOT_DATE=20260415T000000Z

RUN set -eux; \
    rm -f /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources; \
    { \
        echo "Types: deb"; \
        echo "URIs: https://snapshot.debian.org/archive/debian/${APT_SNAPSHOT_DATE}/"; \
        echo "Suites: bookworm bookworm-updates"; \
        echo "Components: main"; \
        echo "Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg"; \
        echo "Check-Valid-Until: no"; \
        echo ""; \
        echo "Types: deb"; \
        echo "URIs: https://snapshot.debian.org/archive/debian-security/${APT_SNAPSHOT_DATE}/"; \
        echo "Suites: bookworm-security"; \
        echo "Components: main"; \
        echo "Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg"; \
        echo "Check-Valid-Until: no"; \
    } > /etc/apt/sources.list.d/snapshot.sources

WORKDIR /app

RUN apt-get -o Acquire::Check-Valid-Until=false update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    git \
    libpq-dev \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-kor \
    tesseract-ocr-jpn \
    tesseract-ocr-chi-sim \
    libtesseract-dev \
    && rm -rf /var/lib/apt/lists/*

# ── pip lockfile install ─────────────────────────────────────────────────────
# `requirements.txt` is generated by `scripts/lock-python-deps.sh` from
# `requirements.in` and pins every transitive dep to a specific version PLUS
# a sha256 hash for every published wheel/sdist. `--require-hashes` makes pip
# fail loudly if a package or hash drifts. `requirements-vcs.txt` carries the
# OpenAI CLIP git+ URL pinned to a specific commit SHA (a commit SHA IS itself
# a content hash, so reproducibility is preserved without a wheel hash).
COPY requirements.txt requirements-vcs.txt ./
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir --require-hashes -r requirements.txt && \
    pip install --no-cache-dir --no-deps -r requirements-vcs.txt

# Runtime stage — MUST stay pinned to the same Python point release as the
# builder above. /opt/venv was built against that exact CPython ABI, so a
# mismatch would silently break extension modules (psycopg2, pillow, etc.).
FROM python:3.11.10-slim-bookworm

# ── apt snapshot pin (runtime stage) ─────────────────────────────────────────
# Same lock as the builder stage above. Keep ARG defaults in lock-step so a
# `docker compose build` without overrides produces identical bits in both
# stages.
ARG APT_SNAPSHOT_DATE=20260415T000000Z

RUN set -eux; \
    rm -f /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources; \
    { \
        echo "Types: deb"; \
        echo "URIs: https://snapshot.debian.org/archive/debian/${APT_SNAPSHOT_DATE}/"; \
        echo "Suites: bookworm bookworm-updates"; \
        echo "Components: main"; \
        echo "Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg"; \
        echo "Check-Valid-Until: no"; \
        echo ""; \
        echo "Types: deb"; \
        echo "URIs: https://snapshot.debian.org/archive/debian-security/${APT_SNAPSHOT_DATE}/"; \
        echo "Suites: bookworm-security"; \
        echo "Components: main"; \
        echo "Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg"; \
        echo "Check-Valid-Until: no"; \
    } > /etc/apt/sources.list.d/snapshot.sources

WORKDIR /app

RUN apt-get -o Acquire::Check-Valid-Until=false update && apt-get install -y --no-install-recommends \
    libpq5 \
    postgresql-client \
    git \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-kor \
    tesseract-ocr-jpn \
    tesseract-ocr-chi-sim \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create hanryx user, AND ensure the lp group (gid 7, owner of /dev/usb/lp0
# on Raspberry Pi OS) exists inside the container with hanryx as a member.
# Baking this at build time means gunicorn (which runs as hanryx via
# entrypoint.sh `su`) can open the USB receipt printer with no runtime
# user-management commands required, regardless of whether the host's lp gid
# happens to be 7. The runtime safety net in entrypoint.sh covers exotic
# hosts where gid != 7.
RUN groupadd -r hanryx \
    && (getent group lp >/dev/null 2>&1 || groupadd -g 7 lp) \
    && useradd -r -g hanryx -G lp -d /app -s /sbin/nologin hanryx

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY . .

RUN mkdir -p /app/card-images /app/data /data && \
    chown -R hanryx:hanryx /app /data

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV FLASK_ENV=production
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

EXPOSE 8080

ENTRYPOINT ["/entrypoint.sh"]
