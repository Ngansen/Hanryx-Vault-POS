# Pinned point release so `docker compose build` on the Pi is reproducible.
# Keep in lock-step with the runtime stage's FROM below — the venv built here
# is copied into the runtime image, so the two Pythons MUST match.
#
# The trailing @sha256:… is the content-addressable digest of the multi-arch
# manifest list. Docker Hub tags are technically mutable (a compromised
# upstream could re-push the same tag with different bits), so pinning by
# digest makes this build tamper-evident: a corrupted or substituted image
# would change the digest and `docker pull` would refuse it. The tag is
# kept for human readability only — the digest is what's actually pulled.
# See `docs/REPRODUCIBILITY.md` for the bump procedure.
FROM python:3.11.10-slim-bookworm@sha256:840e180ebcc6e5c8efab209c43f5e40fd2af98cb49db5c7103c90539c56bb30e AS builder

# ── apt snapshot pin (DISABLED) ──────────────────────────────────────────────
# snapshot.debian.org is unreachable from Docker BuildKit on the Pi after the
# data-root migration. Using default Debian repos from the base image instead.
# Base image is pinned by @sha256 digest so the Debian release is still locked.
# Re-enable when Docker networking to snapshot.debian.org is fixed — see
# `docs/REPRODUCIBILITY.md` for the procedure.
# ARG APT_SNAPSHOT_DATE=20260415T022652Z

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    git \
    libpq-dev \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-kor \
    tesseract-ocr-jpn \
    tesseract-ocr-chi-sim \
    libtesseract-dev \
    && rm -rf /var/lib/apt/lists/*

# ── pip lockfile install ─────────────────────────────────────────────────────
# `requirements.txt` is generated by `scripts/lock-python-deps.sh` from
# `requirements.in` and pins every transitive dep to a specific version PLUS
# a sha256 hash for every published wheel/sdist. `--require-hashes` makes pip
# fail loudly if a package or hash drifts. `requirements-vcs.txt` carries the
# OpenAI CLIP git+ URL pinned to a specific commit SHA (a commit SHA IS itself
# a content hash, so reproducibility is preserved without a wheel hash).
COPY requirements.txt requirements-vcs.txt ./
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
# NOTE on the second install: OpenAI CLIP's setup.py still does
# `from pkg_resources import ...`, but setuptools 81+ (Aug 2025) removed
# pkg_resources from the default install. PEP 517 build isolation creates a
# fresh env that pulls the *latest* setuptools, so CLIP fails to build with
# `ModuleNotFoundError: No module named 'pkg_resources'`. Fix: constrain the
# build env's setuptools to <81 via PIP_CONSTRAINT, which applies to both the
# main install (no-op — already hash-pinned) and the isolated build envs.
RUN pip install --no-cache-dir --require-hashes -r requirements.txt && \
    echo 'setuptools<81' > /tmp/build-constraints.txt && \
    PIP_CONSTRAINT=/tmp/build-constraints.txt \
      pip install --no-cache-dir --no-deps -r requirements-vcs.txt && \
    rm /tmp/build-constraints.txt

# Runtime stage — MUST stay pinned to the same Python point release AND the
# same @sha256 digest as the builder above. /opt/venv was built against that
# exact CPython ABI, so a mismatch would silently break extension modules
# (psycopg2, pillow, etc.). Bumping one without the other is a bug.
FROM python:3.11.10-slim-bookworm@sha256:840e180ebcc6e5c8efab209c43f5e40fd2af98cb49db5c7103c90539c56bb30e

# ── apt snapshot pin (runtime stage — DISABLED) ──────────────────────────────
# Same as builder stage above — snapshot.debian.org disabled until Docker
# networking is fixed. See builder stage comment for details.
# ARG APT_SNAPSHOT_DATE=20260415T022652Z

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    postgresql-client \
    git \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-kor \
    tesseract-ocr-jpn \
    tesseract-ocr-chi-sim \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create hanryx user, AND ensure the lp group (gid 7, owner of /dev/usb/lp0
# on Raspberry Pi OS) exists inside the container with hanryx as a member.
# Baking this at build time means gunicorn (which runs as hanryx via
# entrypoint.sh `su`) can open the USB receipt printer with no runtime
# user-management commands required, regardless of whether the host's lp gid
# happens to be 7. The runtime safety net in entrypoint.sh covers exotic
# hosts where gid != 7.
RUN groupadd -r hanryx \
    && (getent group lp >/dev/null 2>&1 || groupadd -g 7 lp) \
    && useradd -r -g hanryx -G lp -d /app -s /sbin/nologin hanryx

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY . .

RUN mkdir -p /app/card-images /app/data /data && \
    chown -R hanryx:hanryx /app /data

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV FLASK_ENV=production
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

EXPOSE 8080

ENTRYPOINT ["/entrypoint.sh"]
